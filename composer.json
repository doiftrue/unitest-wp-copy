{
  "name": "doiftrue/unitest-wp-copy",
  "type": "library",
  "autoload": {
    "psr-4": {
      "Unitest_WP_Copy\\": "wp-runtime/"
    }
  },
  "require-dev": {
    "composer/installers": "*",
    "wordpress/wordpress": "6.9.*"
  },
  "extra": {
    "installer-paths": {
      "wp-core/": [ "wordpress/wordpress" ]
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://raw.githubusercontent.com/doiftrue/wordpress-composer-repo/main/repo/no-content"
    }
  ]
}
