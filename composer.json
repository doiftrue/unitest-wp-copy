{
  "name": "doiftrue/unitest-wp-copy",
  "description": "Collection of WordPress core functions and classes that can be used in unit tests to simulate WordPress environment.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Timur Kamaev",
      "email": "tnkamaev@gmail.com",
      "homepage": "https://github.com/doiftrue/unitest-wp-copy"
    }
  ],
  "scripts": {
    "phpunit": "phpunit"
  },
  "require": {},
  "require-dev": {
    "composer/installers": "^2.3",
    "wordpress/wordpress": "~6.8.3",
    "phpunit/phpunit": "^9",
    "10up/wp_mock": "*"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "extra": {
    "installer-paths": {
      "wordpress/": [ "wordpress/wordpress" ]
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://raw.githubusercontent.com/doiftrue/wordpress-composer-repo/main/repo/no-content"
    }
  ]
}
